	row.Parent = scroll

	row.MouseButton1Click:Connect(function()
		showInfo(obj)
	end)
end

local function buildCache()
	cachedResults = {}

	if currentMode == "scripts" then
		for _, obj in ipairs(game:GetDescendants()) do
			if passesFilter(obj) then
				table.insert(cachedResults, obj)
			end
		end

	elseif currentMode == "inventory" then
		local backpack = LocalPlayer:FindFirstChild("Backpack")
		local character = LocalPlayer.Character

		if backpack then
			for _, obj in ipairs(backpack:GetDescendants()) do
				table.insert(cachedResults, obj)
			end
		end

		if character then
			for _, obj in ipairs(character:GetDescendants()) do
				table.insert(cachedResults, obj)
			end
		end

	elseif currentMode == "gui" then
		for _, obj in ipairs(PlayerGui:GetDescendants()) do
			table.insert(cachedResults, obj)
		end
	end
end

local function refresh()
	if refreshing then return end
	refreshing = true

	clearList()
	setActive()

	local query = string.lower(search.Text)
	local shown = 0

	for _, obj in ipairs(cachedResults) do
		if shown >= MAX_ROWS then
			break
		end

		if obj and obj.Parent then
			local path = getPath(obj)
			local text = string.lower(obj.Name .. " " .. obj.ClassName .. " " .. path)

			if query == "" or string.find(text, query, 1, true) then
				addRow(obj)
				shown += 1
			end
		end
	end

	countLabel.Text = "Found: " .. shown .. " / " .. #cachedResults
	refreshing = false
end

local function fullRefresh()
	buildCache()
	refresh()
end

